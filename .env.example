# Both variables are optional. The app runs with neither set.

# Path to a specific chromedriver binary. If unset, Selenium Manager
# (bundled with selenium >= 4.6) resolves and downloads a matching
# driver for the Chrome version installed on this machine automatically.
CHROMEDRIVER_PATH=

# Set to 1/true to run Chrome headless (no visible browser window).
# Leave unset to watch the browser navigate as you scrape.
SCRAPER_HEADLESS=
